Version 7.4 (10.10.2021 | DD:MM:YYYY)
Было добавлена первая поддержка загрузки VBE для LightOS:

// TODO -> DONT USE 16 BITS
// TODO -> USE NORMAL BOOT VBE

[BITS 16]
[ORG 0x7C00]

start:
    cli
    xor ax, ax
    mov ds, ax
    mov es, ax
    mov ss, ax
    mov sp, 0x7C00

    mov ax, 0x4F00
    mov di, vbe_info
    int 0x10

    cmp ax, 0x004F
    jne vbe_fail

    mov ax, 0x4F01
    mov cx, 0x118
    mov di, vbe_mode
    int 0x10

    cmp ax, 0x004F
    jne vbe_fail

    mov ax, 0x4F02
    mov bx, 0x4118     ; 0x4000 = LFB + 0x118 mode
    int 0x10

    cmp ax, 0x004F
    jne vbe_fail

    mov ax, [vbe_mode + 40]   ; PhysBasePtr (low)
    mov dx, [vbe_mode + 42]   ; high

hang:
    hlt
    jmp hang

vbe_fail:
    hlt
    jmp vbe_fail

vbe_info:
    times 512 db 0

vbe_mode:
    times 256 db 0

times 510-($-$$) db 0
dw 0xAA55

