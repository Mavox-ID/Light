};

// First few bits reserved for the check state.
define LT_MENU_ITEM_CHECKED (LT_CHECK_CHECKED)
inttype EsButtonFlags uint64_t EsElementFlags {
	LT_BUTTON_DEFAULT = bit 3
	LT_BUTTON_MENU_ITEM = bit 4
	LT_BUTTON_NOT_FOCUSABLE = bit 5
	LT_BUTTON_TOOLBAR = bit 6
	LT_BUTTON_DROPDOWN = bit 7
	LT_BUTTON_COMPACT = bit 8
	LT_BUTTON_CHECKBOX = bit 9
	LT_BUTTON_RADIOBOX = bit 10
	LT_BUTTON_CANCEL = bit 11
	LT_BUTTON_PUSH = bit 12
};
inttype EsMenuItemFlags uint64_t EsButtonFlags {
	LT_MENU_ITEM_HEADER = bit 31
};

inttype EsColorWellFlags uint64_t EsElementFlags {
	LT_COLOR_WELL_HAS_OPACITY = bit 0
};

inttype EsSplitterFlags uint64_t EsElementFlags {
	LT_SPLITTER_VERTICAL = 0
	LT_SPLITTER_HORIZONTAL = bit 0
};

inttype EsListViewFlags uint64_t EsElementFlags {
	LT_LIST_VIEW_HORIZONTAL = bit 0 // Layout horizontally instead of vertically.
	LT_LIST_VIEW_VARIABLE_SIZE = bit 1 // Each item can be a different size. You need to respond to the LIST_VIEW_MEASURE_ITEM message. The size of items cannot depend on the size of the parent.
	LT_LIST_VIEW_TILED = bit 2 // Multiple items per band. Incompatible with variable size items and columns mode.
	LT_LIST_VIEW_SINGLE_SELECT = bit 3 // One item can be selected. By default, selections are disabled.
	LT_LIST_VIEW_MULTI_SELECT = bit 4 // Multiple items can be selected.
	LT_LIST_VIEW_CHOICE_SELECT = bit 5 // Exactly one item is always selected. Dragging on the list view causes the selection to 'slide' between items.
	LT_LIST_VIEW_COLUMNS = bit 6 // Display a column header and let items have multiple values. Incompatible with horizontal and tiled layouts.
	LT_LIST_VIEW_FIXED_ITEMS = bit 7 // Use the fixed item API rather than the callback API.
	LT_LIST_VIEW_CENTER_TILES = bit 8 // Center tiled items.
};

inttype EsListViewGroupFlags uint32_t none {
	LT_LIST_VIEW_GROUP_HAS_HEADER = bit 0 // The first item in the group is a header.
	LT_LIST_VIEW_GROUP_HAS_FOOTER = bit 1 // The last item in the group is a footer.
	LT_LIST_VIEW_GROUP_INDENT = bit 2 // Indent the group's items (excluding the header and footer).
	LT_LIST_VIEW_GROUP_COLLAPSABLE = bit 3 // The group can be collapsed.
};

inttype EsMenuFlags uint32_t none {
	LT_MENU_AT_CURSOR = bit 0
	LT_MENU_MAXIMUM_HEIGHT = bit 1
};

inttype EsFontFlags uint8_t none {
	LT_FONT_ITALIC = bit 0
};

inttype EsTextFigures uint8_t none {
