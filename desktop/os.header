	LT_TEXT_DECORATION_STRIKE_THROUGH = bit 1
};

inttype EsTextDisplayFlags uint64_t EsElementFlags {
	LT_TEXT_DISPLAY_RICH_TEXT = bit 0
	LT_TEXT_DISPLAY_PREFORMATTED = bit 1 // Prevents trimming of trailing/leading whitespace.
	LT_TEXT_DISPLAY_NO_FONT_SUBSTITUTION = bit 2
};

inttype EsListDisplayFlags uint64_t EsElementFlags {
	// First 8 bits reserved for the marker type (see below).
	LT_LIST_DISPLAY_BULLETED = 0
	LT_LIST_DISPLAY_NUMBERED = 1
	LT_LIST_DISPLAY_LOWER_ALPHA = 2
