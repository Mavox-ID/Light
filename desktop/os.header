inttype EsMessageType enum none {
	LT_MSG_INVALID				= 0x0000
		
	// Window manager messages (don't rearrange; see SendMessageToWindow in kernel/window_manager.cpp):
	LT_MSG_WM_START				= 0x1000
	LT_MSG_MOUSE_MOVED 			= 0x1001
	LT_MSG_WINDOW_ACTIVATED			= 0x1002
	LT_MSG_WINDOW_DEACTIVATED		= 0x1003
	LT_MSG_WINDOW_DESTROYED 		= 0x1004
	LT_MSG_MOUSE_EXIT			= 0x1006 
	LT_MSG_WINDOW_RESIZED			= 0x1007
	LT_MSG_MOUSE_LEFT_DOWN 			= 0x1008	// Return LT_REJECTED to prevent taking focus, even if LT_ELEMENT_FOCUSABLE is set. Propagates.
	LT_MSG_MOUSE_LEFT_UP 			= 0x1009	// Propagates.
	LT_MSG_MOUSE_RIGHT_DOWN 		= 0x100A	// Propagates.
	LT_MSG_MOUSE_RIGHT_UP 			= 0x100B	// Propagates.
	LT_MSG_MOUSE_MIDDLE_DOWN 		= 0x100C	// Propagates.
	LT_MSG_MOUSE_MIDDLE_UP 			= 0x100D 	// Propagates.
	LT_MSG_KEY_DOWN				= 0x100E	// Propagates to ancestors if unhandled.
	LT_MSG_KEY_UP				= 0x100F
	LT_MSG_UPDATE_WINDOW			= 0x1010
	LT_MSG_SCROLL_WHEEL			= 0x1011
	LT_MSG_WM_END				= 0x13FF

	// Internal GUI messages:				// None of these should be sent directly.
	LT_MSG_PAINT				= 0x2000	// Paint the element using the painter specified in the message.
	LT_MSG_PAINT_BACKGROUND			= 0x2001	// Paint the element's background. Sent before LT_MSG_PAINT. 
								// If unhandled, the background is drawn using the default settings. 
								// The width/height parameters of EsPainter may be larger than expected - this includes the 'non-client' area.
	LT_MSG_GET_CURSOR			= 0x2003	// Get the cursor for the element.
	LT_MSG_ANIMATE				= 0x2004	// Animate the element. Returns the number of microseconds to wait for the next frame, 
								// or whether the animation is complete.
	LT_MSG_Z_ORDER				= 0x2005	// Get the child of an element based on its Z-order.
	LT_MSG_DESTROY				= 0x2006	// The element has been marked to be destroyed. Free any resources allocated. 
								// Sent after the parent receives its LT_MSG_REMOVE_CHILD message.
	LT_MSG_GET_WIDTH			= 0x2007	// Measure the element's width. If known, the height is specified.
	LT_MSG_GET_HEIGHT			= 0x2008	// Measure the element's height. If known, the width is specified.
	LT_MSG_LAYOUT				= 0x2009	// The size of the element has been updated. Layout the element's children.
	LT_MSG_ENSURE_VISIBLE			= 0x200A	// Center the specified child (where possible) in your scrolled viewport.
	LT_MSG_ADD_CHILD			= 0x200B	// An element has been created with this element as its parent.
	LT_MSG_REMOVE_CHILD			= 0x200C	// An element has been destroyed with this element as its parent. 
								// Sent before the child receives its LT_MSG_DESTROY message. 
								// It will be removed from the `children` later (but before the next LT_MSG_LAYOUT message is received).
	LT_MSG_PRE_ADD_CHILD			= 0x200D	// An element has been created with this element as its parent, but is not yet added to the parent.
	LT_MSG_HIT_TEST				= 0x200E	// For non-rectangular elements: test whether a pixel should be considered inside the element. Set response to LT_HANDLED.
	LT_MSG_KEY_TYPED			= 0x2011	// Sent to the focused element when a key is pressed. 
								// Only if LT_HANDLED is returned the message will not propagate; 
								// this allows messageUser to block input processing by returning LT_REJECTED.
	LT_MSG_SCROLL_X				= 0x2012	// The element has been horizontally scrolled.
	LT_MSG_SCROLL_Y				= 0x2013	// The element has been vertically scrolled.
	LT_MSG_STRONG_FOCUS_END			= 0x2014	// Sent once when the user 'clicks off' the element, even if a new element was not necessarily focused. Not sent when destroying the element!
	LT_MSG_BEFORE_Z_ORDER			= 0x2015	// Sent before a batch of Z_ORDER messages.
	LT_MSG_AFTER_Z_ORDER			= 0x2016	// Sent after a batch of Z_ORDER messages.
	LT_MSG_PAINT_CHILDREN			= 0x2017	// Paint the element's children. Useful for animations, with EsPaintTargetTake/Return.
	LT_MSG_DESTROY_CONTENTS			= 0x2018	// Sent after EsElementDestroyContents is called.
	LT_MSG_GET_INSPECTOR_INFORMATION	= 0x2019	// Get a string containing information about the element to display in the inspector.
	LT_MSG_NOT_VISIBLE			= 0x2020	// Sent to elements in the check visible list when they move off-screen.
	LT_MSG_GET_CHILD_STYLE_VARIANT		= 0x2021	// Allows the parent of an element to customize its default style.
	LT_MSG_PAINT_ICON			= 0x2022	// Sent during EsDrawContent.
	LT_MSG_MOUSE_LEFT_CLICK			= 0x2023	// Indicates the element has been "clicked" (might be different for other input devices).
	LT_MSG_MOUSE_RIGHT_CLICK		= 0x2024	// Right click, similar to LEFT_CLICK above.
	LT_MSG_MOUSE_MIDDLE_CLICK		= 0x2025	// Middle click, similar to LEFT_CLICK above.
	LT_MSG_MOUSE_LEFT_DRAG			= 0x2026	// Left button is pressed and the mouse is moving. 
								// Only starts being sent after a threshold is reached. 
								// This will NOT be sent if the element did not handle LEFT_DOWN.
	LT_MSG_MOUSE_RIGHT_DRAG			= 0x2027	// Similar to LEFT_DRAG above, but for the right button. 
	LT_MSG_MOUSE_MIDDLE_DRAG		= 0x2028	// Similar to LEFT_DRAG above, but for the middle button. 
	LT_MSG_GET_ACCESS_KEY_HINT_BOUNDS	= 0x2029	// Get the bounds to display an access key hint.
	LT_MSG_UI_SCALE_CHANGED			= 0x202A	// The UI scale has changed.
	LT_MSG_TRANSITION_COMPLETE		= 0x202B	// The transition started with EsElementStartTransition completed.
	LT_MSG_PAINT_FOREGROUND			= 0x202C	// Paint the element's foreground. Sent after the children are painted.
								// The width/height parameters of EsPainter may be larger than expected - this includes the 'non-client' area.
	LT_MSG_PRIMARY_CLIPBOARD_UPDATED	= 0x202D	// Send to the focused element when the contents of the primary clipboard is changes.
								// This message might be delayed if the window containing the element is inactive.

	// State change messages: (causes a style refresh)
	LT_MSG_STATE_CHANGE_MESSAGE_START	= 0x2080
	LT_MSG_HOVERED_START			= 0x2081	// Sent when the mouse starts hovering over an element.
	LT_MSG_HOVERED_END			= 0x2082	// Opposite of LT_MSG_HOVERED_START. Sent before LT_MSG_HOVERED_START is sent to the new hovered element. Not sent when destroying the element!
	LT_MSG_PRESSED_START			= 0x2083	// Sent when an element is pressed.
	LT_MSG_PRESSED_END			= 0x2084	// Opposite of LT_MSG_PRESSED_START. Not sent when destroying the element!
	LT_MSG_FOCUSED_START			= 0x2085	// Sent when an element is focused.
	LT_MSG_FOCUSED_END			= 0x2086	// Opposite of LT_MSG_FOCUSED_START. Not sent when destroying the element!
	LT_MSG_FOCUS_WITHIN_START		= 0x2087	// Sent when an element is focused.
	LT_MSG_FOCUS_WITHIN_END			= 0x2088	// Opposite of LT_MSG_FOCUSED_START. Not sent when destroying the element!
	LT_MSG_STATE_CHANGE_MESSAGE_END		= 0x20FF

	// Element messages:
	LT_MSG_SCROLLBAR_MOVED			= 0x3000	// The scrollbar has been moved.
	LT_MSG_CHECK_UPDATED			= 0x3001	// Button's check state has changed. See message->checkState.
	LT_MSG_RADIO_GROUP_UPDATED		= 0x3002	// Sent to all siblings of a radiobox when it is checked, so they can uncheck themselves.
	LT_MSG_COLOR_CHANGED			= 0x3003	// Color well's color has changed. See message->colorChanged.
	LT_MSG_LIST_DISPLAY_GET_MARKER		= 0x3004	// Get the string for a marker in an EsListDisplay. See message->getContent.
	LT_MSG_SLIDER_MOVED			= 0x3006	// The slider has been moved.

	// Undo item messages:
	LT_MSG_UNDO_CANCEL			= 0x4D00
	LT_MSG_UNDO_INVOKE			= 0x4D01
	LT_MSG_UNDO_TO_STRING			= 0x4D02

	// File Manager messages:
	LT_MSG_FILE_MANAGER_FILE_MODIFIED	= 0x5100
	LT_MSG_FILE_MANAGER_PATH_MOVED		= 0x5101
	LT_MSG_FILE_MANAGER_DOCUMENT_UPDATE	= 0x5102	// The managed list of open documents has been updated.

	// Textbox messages:
	LT_MSG_TEXTBOX_UPDATED			= 0x5200
	LT_MSG_TEXTBOX_EDIT_START		= 0x5201 	// Set LT_TEXTBOX_EDIT_BASED to receive.
	LT_MSG_TEXTBOX_EDIT_END			= 0x5202 	// Set LT_TEXTBOX_EDIT_BASED to receive.
	LT_MSG_TEXTBOX_NUMBER_DRAG_START	= 0x5203 	// For EsTextboxUseNumberOverlay.
	LT_MSG_TEXTBOX_NUMBER_DRAG_END		= 0x5204 	// For EsTextboxUseNumberOverlay.
	LT_MSG_TEXTBOX_NUMBER_DRAG_DELTA	= 0x5205 	// For EsTextboxUseNumberOverlay.
	LT_MSG_TEXTBOX_NUMBER_UPDATED		= 0x5206 	// For EsTextboxUseNumberOverlay with defaultBehaviour=true.
	LT_MSG_TEXTBOX_GET_BREADCRUMB		= 0x5207 	// For EsTextboxUseBreadcrumbOverlay.
	LT_MSG_TEXTBOX_ACTIVATE_BREADCRUMB	= 0x5208 	// For EsTextboxUseBreadcrumbOverlay.

	// List view messages:
	LT_MSG_LIST_VIEW_FIND_INDEX		= 0x5301
	LT_MSG_LIST_VIEW_MEASURE_RANGE		= 0x5302
	LT_MSG_LIST_VIEW_MEASURE_ITEM		= 0x5303
	LT_MSG_LIST_VIEW_CREATE_ITEM		= 0x5304
	LT_MSG_LIST_VIEW_GET_CONTENT		= 0x5305
	LT_MSG_LIST_VIEW_GET_INDENT		= 0x5306
	LT_MSG_LIST_VIEW_FIND_POSITION		= 0x5307
	LT_MSG_LIST_VIEW_IS_SELECTED		= 0x5308
	LT_MSG_LIST_VIEW_SELECT			= 0x5309
	LT_MSG_LIST_VIEW_SELECT_RANGE		= 0x530A
	LT_MSG_LIST_VIEW_CHOOSE_ITEM		= 0x530B
	LT_MSG_LIST_VIEW_SEARCH			= 0x530C
	LT_MSG_LIST_VIEW_CONTEXT_MENU		= 0x530D
	LT_MSG_LIST_VIEW_COLUMN_MENU		= 0x530E
	LT_MSG_LIST_VIEW_GET_SUMMARY		= 0x530F
	LT_MSG_LIST_VIEW_GET_COLUMN_SORT	= 0x5310
	LT_MSG_LIST_VIEW_GET_ITEM_DATA		= 0x5311

	// Reorder list messages:
	LT_MSG_REORDER_ITEM_TEST		= 0x5400
	LT_MSG_REORDER_ITEM_MOVED		= 0x5401

	// Application messages:
	LT_MSG_APPLICATION_EXIT			= 0x6001
	LT_MSG_INSTANCE_CREATE			= 0x6002
	LT_MSG_DEVICE_CONNECTED			= 0x6003
	LT_MSG_DEVICE_DISCONNECTED		= 0x6004

	// Instance messages:
	LT_MSG_INSTANCE_OPEN			= 0x6800
	LT_MSG_INSTANCE_SAVE			= 0x6801
	LT_MSG_INSTANCE_DESTROY			= 0x6802
	LT_MSG_INSTANCE_CLOSE			= 0x6803

	// Messages for internal use by the system:
	LT_MSG_SYSTEM_START			= 0x7000
	LT_MSG_SYSTEM_END			= 0x7FFF

	// User messages:
	LT_MSG_USER_START			= 0x8000
	LT_MSG_USER_END				= 0xBFFF
}

inttype EsCursorStyle enum none {
	LT_CURSOR_NORMAL 
	LT_CURSOR_TEXT 
	LT_CURSOR_RESIZE_VERTICAL 
	LT_CURSOR_RESIZE_HORIZONTAL
	LT_CURSOR_RESIZE_DIAGONAL_1 // '/'
	LT_CURSOR_RESIZE_DIAGONAL_2 // '\'
	LT_CURSOR_SPLIT_VERTICAL
	LT_CURSOR_SPLIT_HORIZONTAL
	LT_CURSOR_HAND_HOVER
	LT_CURSOR_HAND_DRAG
	LT_CURSOR_HAND_POINT
	LT_CURSOR_SCROLL_UP_LEFT
	LT_CURSOR_SCROLL_UP
	LT_CURSOR_SCROLL_UP_RIGHT
	LT_CURSOR_SCROLL_LEFT
	LT_CURSOR_SCROLL_CENTER
	LT_CURSOR_SCROLL_RIGHT
	LT_CURSOR_SCROLL_DOWN_LEFT
	LT_CURSOR_SCROLL_DOWN
	LT_CURSOR_SCROLL_DOWN_RIGHT
	LT_CURSOR_SELECT_LINES
	LT_CURSOR_DROP_TEXT
	LT_CURSOR_CROSS_HAIR_PICK
	LT_CURSOR_CROSS_HAIR_RESIZE
	LT_CURSOR_MOVE_HOVER
	LT_CURSOR_MOVE_DRAG
