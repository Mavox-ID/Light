inttype EsScrollViewMode uint8_t none {
	LT_SCROLL_MODE_NONE   = 0 // No scrolling takes place on this axis.
	LT_SCROLL_MODE_HIDDEN = 1 // Scrolling takes place, but there is no visible scrollbar.
	LT_SCROLL_MODE_FIXED  = 2 // The scrollbar is always visible.
	LT_SCROLL_MODE_AUTO   = 3 // The scrollbar is only visible if the content is larger than the viewport.
};
