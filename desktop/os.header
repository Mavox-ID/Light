opaque_type EsTextDisplay      EsElement;
opaque_type EsIconDisplay      EsElement;
opaque_type EsTextbox          EsElement;
opaque_type EsListView         EsElement;
opaque_type EsMenu             EsElement;
opaque_type EsColorWell        EsElement;
opaque_type EsSplitter         EsElement;
opaque_type EsImageDisplay     EsElement;
opaque_type EsListDisplay      EsElement;
opaque_type EsCanvasPane       EsElement;
opaque_type EsSlider           EsElement;
opaque_type EsScrollView       EsElement;
opaque_type EsSpacer           EsElement;
opaque_type EsTextPlan         none;
opaque_type EsPaintTarget      none;
opaque_type EsUndoManager      none;
opaque_type EsHeap             none;
opaque_type EsFileStore        none;
opaque_type EsUserTask         none;
opaque_type EsBundle           none;
opaque_type EsDialog           none;

type_name uint8_t EsNodeType;
type_name uintptr_t EsHandle;
type_name uint64_t EsFileOffset;
type_name int64_t EsFileOffsetDifference;
type_name uint64_t EsAudioDeviceID;
type_name uint16_t EsFontFamily;
type_name uint64_t EsTimer;
type_name int64_t EsListViewIndex;
type_name uint64_t EsObjectID;
type_name uint32_t EsDeviceColor; // TODO Make this 64-bit?
type_name uint32_t EsStyleID;

define LT_FLAGS_DEFAULT (0)

define LT_INVALID_HANDLE  ((EsHandle) (0))
define LT_CURRENT_THREAD  ((EsHandle) (0x10))
define LT_CURRENT_PROCESS ((EsHandle) (0x11))

define LT_WAIT_NO_TIMEOUT (-1)
define LT_MAX_WAIT_COUNT  (8)

define LT_MAX_DIRECTORY_CHILD_NAME_LENGTH (256)

define LT_PROCESS_EXECUTABLE_NOT_LOADED     (0)
define LT_PROCESS_EXECUTABLE_FAILED_TO_LOAD (1)
define LT_PROCESS_EXECUTABLE_LOADED         (2)

define LT_SNAPSHOT_MAX_PROCESS_NAME_LENGTH (31)
define LT_SYSTEM_SNAPSHOT_PROCESSES        (1)

// Message responses:
// 0 is unhandled.
define LT_HANDLED  (-1)
define LT_REJECTED (-2)

define LT_NODE_FILE      (0x00)
define LT_NODE_DIRECTORY (0x10)
define LT_NODE_INVALID   (0x20)

define LT_DIRECTORY_CHILDREN_UNKNOWN ((EsFileOffsetDifference) (-1))

define LT_MEMORY_MAP_OBJECT_ALL (0) // Set size to this to map the entire object.

define LT_SHARED_MEMORY_READ_WRITE (1 << 0)

define LT_STRING_FORMAT_ENOUGH_SPACE (-1)

define LT_PANEL_BAND_SIZE_DEFAULT (-1)

define LT_SCROLLBAR_VERTICAL   (0 << 0)
define LT_SCROLLBAR_HORIZONTAL (1 << 0)

// Standard font families:
define LT_FONT_SANS       (0xFFFF)
define LT_FONT_SERIF      (0xFFFE)
define LT_FONT_MONOSPACED (0xFFFD)

// Font weights:
define LT_FONT_REGULAR  (4)
define LT_FONT_SEMIBOLD (6)
define LT_FONT_BOLD     (7)

define LT_COMMAND_SYSTEM_START		(0xF0000000)
define LT_COMMAND_DELETE		(0xF0000001)
define LT_COMMAND_SELECT_ALL		(0xF0000002)
define LT_COMMAND_CUT			(0xF0000003)
define LT_COMMAND_COPY			(0xF0000004)
define LT_COMMAND_PASTE			(0xF0000005)
define LT_COMMAND_UNDO			(0xF0000006)
define LT_COMMAND_REDO			(0xF0000007)
define LT_COMMAND_SAVE			(0xF0000008)
define LT_COMMAND_SHOW_IN_FILE_MANAGER	(0xF0000009)

define LT_WINDOW_MOVE_MAXIMIZED (1 << 0)
define LT_WINDOW_MOVE_ADJUST_TO_FIT_SCREEN (1 << 1)
define LT_WINDOW_MOVE_HIDDEN (1 << 2)
define LT_WINDOW_MOVE_ALWAYS_ON_TOP (1 << 3)
define LT_WINDOW_MOVE_AT_BOTTOM (1 << 4)
define LT_WINDOW_MOVE_UPDATE_SCREEN (1 << 5)
define LT_WINDOW_MOVE_DYNAMIC (1 << 6)

define LT_WINDOW_SOLID_TRUE (1 << 0)
define LT_WINDOW_SOLID_NO_ACTIVATE (1 << 1)
define LT_WINDOW_SOLID_NO_BRING_TO_FRONT (1 << 2)

define LT_GAME_CONTROLLER_MAX_COUNT (16)

define LT_DOMAIN_NAME_MAX_LENGTH (255)
define LT_ECHO_REQUEST_MAX_LENGTH (48)

define LT_INSTANCE_CLASS_VIEWER (0) // Default.
define LT_INSTANCE_CLASS_EDITOR (1)

define LT_MOUNT_POINT_MAX_COUNT (256)

define LT_THREAD_EVENT_MUTEX_ACQUIRE (1)
define LT_THREAD_EVENT_MUTEX_RELEASE (2)

define LT_WINDOW_PROPERTY_SOLID         (0x01) // Standard window properties.
define LT_WINDOW_PROPERTY_OPAQUE_BOUNDS (0x02)
define LT_WINDOW_PROPERTY_BLUR_BOUNDS   (0x03)
define LT_WINDOW_PROPERTY_ALPHA         (0x04)
define LT_WINDOW_PROPERTY_FOCUSED       (0x05)
define LT_WINDOW_PROPERTY_MATERIAL      (0x06)
define LT_WINDOW_PROPERTY_EMBED         (0x07)
define LT_WINDOW_PROPERTY_EMBED_INSETS  (0x08)
define LT_WINDOW_PROPERTY_OBJECT        (0x81) // Embedded window properties.
define LT_WINDOW_PROPERTY_EMBED_OWNER   (0x82)

define LT_DRAW_BITMAP_OPAQUE (0xFFFF)
define LT_DRAW_BITMAP_XOR    (0xFFFE)
define LT_DRAW_BITMAP_BLEND  (0)

define LT_SCROLL_WHEEL_NOTCH (0x100)

define LT_SHUTDOWN_ACTION_POWER_OFF (1)
define LT_SHUTDOWN_ACTION_RESTART (2)

