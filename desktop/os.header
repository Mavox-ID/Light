inttype EsProcessStateFlags uint8_t none {
	LT_PROCESS_STATE_ALL_THREADS_TERMINATED = bit 0
	LT_PROCESS_STATE_TERMINATING = bit 1
	LT_PROCESS_STATE_CRASHED = bit 2
	LT_PROCESS_STATE__PINGED = bit 3
	LT_PROCESS_STATE__PAUSED_FROM_CRASH = bit 4
};

inttype EsError intptr_t none {
	LT_SUCCESS = -1

	// Networking errors:
	LT_ERROR_NO_ADDRESS_FOR_DOMAIN_NAME = -1000
	LT_ERROR_NO_CONNECTED_NETWORK_INTERFACES = -1001
	LT_ERROR_BAD_DOMAIN_NAME = -1002
	LT_ERROR_LOST_IP_ADDRESS = -1003
	LT_ERROR_CONNECTION_RESET = -1004
	LT_ERROR_CONNECTION_REFUSED = -1005
	LT_ERROR_BUFFER_TOO_SMALL = -1006

	// File system errors:
	LT_ERROR_OPERATION_BLOCKED = -2000 // Somebody else has opened the node with flags blocking this operation.
	LT_ERROR_ACCESS_NOT_WITHIN_FILE_BOUNDS = -2001 
	LT_ERROR_DIRECTORY_NOT_EMPTY = -2004
	LT_ERROR_NODE_DELETED = -2005
	LT_ERROR_FILE_TOO_LARGE = -2006 // Errors caused by the file being too large. For example, the file system might impose a maximum size limit on files, or it might impose a limit on how fragmented a file may become.
	LT_ERROR_DRIVE_FULL = -2007
	LT_ERROR_CORRUPT_DATA = -2008
	LT_ERROR_INVALID_NAME = -2009
	LT_ERROR_FILE_ON_READ_ONLY_VOLUME = -2011
	LT_ERROR_PATH_NOT_WITHIN_MOUNTED_VOLUME = -2013
	LT_ERROR_PATH_NOT_TRAVERSABLE = -2014
	LT_ERROR_DEVICE_REMOVED = -2015
	LT_ERROR_INCORRECT_NODE_TYPE = -2016
	LT_ERROR_FILE_DOLT_NOT_EXIST = -2017
	LT_ERROR_COULD_NOT_RESIZE_FILE = -2018 // TODO Replace with ERROR_HARDWARE_FAILURE/ERROR_CORRUPT_DATA/ERROR_DRIVE_FULL/ERROR_FILE_TOO_LARGE.
	LT_ERROR_VOLUME_MISMATCH = -2019
	LT_ERROR_TARGET_WITHIN_SOURCE = -2020

	// General errors:
	LT_ERROR_UNKNOWN = -3000
	LT_ERROR_ALREADY_EXISTS = -3001
	LT_ERROR_CANCELLED = -3002
	LT_ERROR_INSUFFICIENT_RESOURCES = -3003
	LT_ERROR_PERMISSION_NOT_GRANTED = -3004
	LT_ERROR_UNSUPPORTED = -3005
	LT_ERROR_HARDWARE_FAILURE = -3006 

	// Internal errors (not be returned by any API function):
	LT_ERROR_NODE_NOT_LOADED = -4001
	LT_ERROR_DIRECTORY_ENTRY_BEING_REMOVED = -4002
	LT_ERROR_COULD_NOT_RESOLVE_SYMBOL = -4003
	LT_ERROR_NO_MESSAGES_AVAILABLE = -4004
	LT_ERROR_INVALID_DIMENSIONS = -4005
	LT_ERROR_TOO_MANY_FILLT_WITH_NAME = -4006

	// Errors specific to a single function:
	LT_ERROR_MESSAGE_QUEUE_FULL = -5000 // EsMessagePost.
	LT_ERROR_TIMEOUT_REACHED = -5001 // EsWait.
	LT_ERROR_BLOCK_ACCESS_INVALID = -5002 // LT_DEVICE_CONTROL_BLOCK_READ/LT_DEVICE_CONTROL_BLOCK_WRITE.
};

inttype EsTextFlags uint32_t none {
	LT_TEXT_H_LEFT = bit 0
	LT_TEXT_H_CENTER = bit 1
	LT_TEXT_H_RIGHT = bit 2
	LT_TEXT_V_TOP = bit 3
	LT_TEXT_V_CENTER = bit 4
	LT_TEXT_V_BOTTOM = bit 5
	LT_TEXT_ELLIPSIS = bit 6
	LT_TEXT_WRAP = bit 7
};

inttype EsTextPlanFlags uint32_t EsTextFlags {
	LT_TEXT_PLAN_SINGLE_USE = bit 8
	LT_TEXT_PLAN_TRIM_SPACES = bit 9
	LT_TEXT_PLAN_RTL = bit 10
	LT_TEXT_PLAN_CLIP_UNBREAKABLE_LINES = bit 11
	LT_TEXT_PLAN_NO_FONT_SUBSTITUTION = bit 12
};

inttype EsDrawContentFlags uint32_t EsTextFlags {
	LT_DRAW_CONTENT_TABULAR = bit 8
	LT_DRAW_CONTENT_MARKER_DOWN_ARROW = bit 9
	LT_DRAW_CONTENT_MARKER_UP_ARROW = bit 10
	LT_DRAW_CONTENT_RICH_TEXT = bit 11
};

inttype EsListViewColumnFlags uint32_t EsDrawContentFlags {
	LT_LIST_VIEW_COLUMN_HAS_MENU           =    bit 16  // The header can be clicked to open a menu.
	LT_LIST_VIEW_COLUMN_DATA_STRINGS       = ( 0 << 22) // Data types for fixed items or GET_ITEM_DATA.
	LT_LIST_VIEW_COLUMN_DATA_INTEGERS      = ( 1 << 22)
	LT_LIST_VIEW_COLUMN_DATA_DOUBLES       = ( 2 << 22)
	LT_LIST_VIEW_COLUMN_DATA_MASK          = ( 3 << 22)
	LT_LIST_VIEW_COLUMN_SORT_DEFAULT       = ( 0 << 24) // Sort types for fixed items or GET_ITEM_DATA.
	LT_LIST_VIEW_COLUMN_SORT_TIME          = ( 1 << 24)
	LT_LIST_VIEW_COLUMN_SORT_SIZE          = ( 2 << 24)
	LT_LIST_VIEW_COLUMN_SORT_NONE          = ( 3 << 24)
	LT_LIST_VIEW_COLUMN_SORT_MASK          = ( 7 << 24)
	LT_LIST_VIEW_COLUMN_FORMAT_DEFAULT     = ( 0 << 27) // Format types for fixed items or GET_ITEM_DATA.
	LT_LIST_VIEW_COLUMN_FORMAT_YLT_NO      = ( 1 << 27)
	LT_LIST_VIEW_COLUMN_FORMAT_ON_OFF      = ( 2 << 27)
	LT_LIST_VIEW_COLUMN_FORMAT_PERCENTAGE  = ( 3 << 27)
	LT_LIST_VIEW_COLUMN_FORMAT_BYTES       = ( 4 << 27)
	LT_LIST_VIEW_COLUMN_FORMAT_BITS        = ( 5 << 27) 
	LT_LIST_VIEW_COLUMN_FORMAT_BYTE_RATE   = ( 6 << 27) // Bytes per second.
	LT_LIST_VIEW_COLUMN_FORMAT_SECONDS     = ( 7 << 27) 
	LT_LIST_VIEW_COLUMN_FORMAT_HERTZ       = ( 8 << 27) 
	LT_LIST_VIEW_COLUMN_FORMAT_PIXELS      = ( 9 << 27)
	LT_LIST_VIEW_COLUMN_FORMAT_DPI         = (10 << 27)
	LT_LIST_VIEW_COLUMN_FORMAT_ENUM_STRING = (11 << 27)
	LT_LIST_VIEW_COLUMN_FORMAT_MASK        = (31 << 27)
};

// For LT_MSG_LIST_VIEW_GET_COLUMN_SORT.
inttype EsListViewGetColumnSortFlags uint32_t none {
	LT_LIST_VIEW_COLUMN_SORT_ASCENDING = bit 0
	LT_LIST_VIEW_COLUMN_SORT_DESCENDING = bit 1
};

inttype EsFileOpenFlags uint32_t none {
	// TODO Cleanup!

	LT_FILE_READ_SHARED = bit 0		 // Read-only. The file can still be opened for writing.
	LT_FILE_READ = bit 1			 // Read-only. The file will not openable for writing. This will fail if the file is already opened for writing.
	LT_FILE_WRITE_SHARED = bit 2		 // Read-write. The file can still be opened for writing. This will fail if the file is already opened for exclusive writing.
	LT_FILE_WRITE = bit 3 			 // Read-write. The file will not openable for writing. This will fail if the file is already opened for writing.

	LT_NODE_FAIL_IF_FOUND = bit 16
	LT_NODE_FAIL_IF_NOT_FOUND = bit 17
	LT_NODE_PREVENT_RESIZE = bit 18
	LT_NODE_CREATE_DIRECTORIES = bit 19 	// Create the directories leading to the file, if they don't already exist.

	LT__NODE_FROM_WRITE_EXCLUSIVE = bit 21
	LT__NODE_DIRECTORY_WRITE = bit 22
	LT__NODE_NO_WRITE_BASE = bit 23
};

inttype EsMemoryMapFlags uint32_t none {
	LT_MEMORY_MAP_OBJECT_READ_WRITE = bit 0
	LT_MEMORY_MAP_OBJECT_READ_ONLY = bit 1
	LT_MEMORY_MAP_OBJECT_COPY_ON_WRITE = bit 2 // Files only.
};

// Flags set with %f.
inttype EsStringFormatFlags uint32_t none {
	LT_STRING_FORMAT_SIMPLE = bit 0
};

define LT_PERMISSION_ALL ((_EsLongConstant) (-1))
inttype EsProcessPermissions uint64_t none {
	LT_PERMISSION_NETWORKING = bit 0
	LT_PERMISSION_PROCESS_CREATE = bit 1
	LT_PERMISSION_PROCESS_OPEN = bit 2
	LT_PERMISSION_SCREEN_MODIFY = bit 3
	LT_PERMISSION_SHUTDOWN = bit 4
	LT_PERMISSION_TAKE_SYSTEM_SNAPSHOT = bit 5
	LT_PERMISSION_GET_VOLUME_INFORMATION = bit 6
	LT_PERMISSION_WINDOW_MANAGER = bit 7
	LT_PERMISSION_POSIX_SUBSYSTEM = bit 8
	LT_PERMISSION_INHERIT = bit 63
};

// Element flags - bits 0-31 for custom use; bits 32-63 common to all elements.

inttype EsElementFlags uint64_t none {
	// Common element flags:
	LT_ELEMENT_FOCUSABLE = bit 32
	LT_ELEMENT_HIDDEN = bit 33 // Hides the element and descendents. Also prevents the element and descendents from taking focus or being hovered/pressed.
	LT_ELEMENT_DISABLED = bit 34 // Prevents the element from taking focus or being pressed.
	LT_ELEMENT_DEBUG = bit 35 // Prints some extra debug information about the element.
	LT_ELEMENT_NO_CLIP = bit 36 // Do not clip children to the element's bounds.
	LT_ELEMENT_NO_HOVER = bit 37 // For z-stacked elements. Can still hover descendents and overlapped siblings/parent. Override HIT_TEST to return false to prevent hovering descendents.
	LT_ELEMENT_NO_HOVER_DESCENDENTS = bit 38 // Prevent hovering over any descendents.
	LT_ELEMENT_BLOCK_FOCUS = bit 39 // This element and descendents cannot take focus.
	LT_ELEMENT_NOT_TAB_TRAVERSABLE = bit 40 // Use with LT_ELEMENT_FOCUSABLE to indicate the element cannot be focused from tab traversal.
	LT_ELEMENT_NO_FOCUS_ON_CLICK = bit 41 // Use with LT_ELEMENT_FOCUSABLE to indicate the element cannot be focused by clicking it.
	LT_ELEMENT_LAYOUT_HINT_HORIZONTAL = bit 43 // Hint for autoCorners and autoBorders.
	LT_ELEMENT_LAYOUT_HINT_REVERSE = bit 44 // Hint for autoCorners and autoBorders; and tab traversal.
	LT_ELEMENT_STICKY_ACCESS_KEY = bit 45 // Don't exit access key mode after using the access key.
	LT_ELEMENT_NON_CLIENT = bit 46 
	LT_ELEMENT_FREE_USER_DATA = bit 47 // Call EsHeapFree on userData when destroying the element.
	LT_ELEMENT_AUTO_GROUP = bit 48 // Enables autoCorners and autoBorders.

	// For children of splitters:
	LT_CELL_COLLAPSABLE = bit 51

	// Cell layout flags:
	LT_CELL_H_PUSH = bit 54
	LT_CELL_H_EXPAND = bit 55
	LT_CELL_H_SHRINK = bit 56
	LT_CELL_H_LEFT = bit 57
	LT_CELL_H_RIGHT = bit 58
	LT_CELL_V_PUSH = bit 59
	LT_CELL_V_EXPAND = bit 60
	LT_CELL_V_SHRINK = bit 61
	LT_CELL_V_TOP = bit 62
	LT_CELL_V_BOTTOM = bit 63
};

inttype EsPanelFlags uint64_t EsElementFlags {
	// Defaults.
	LT_PANEL_STACK			= 0
	LT_PANEL_VERTICAL		= 0
	LT_PANEL_SWITCHER_MEASURE_SHOWN = 0 // Use the shown child to determine size.

	LT_PANEL_SWITCHER = bit 0
	LT_PANEL_Z_STACK = bit 1
	LT_PANEL_TABLE = bit 2

	LT_PANEL_H_SCROLL_FIXED = bit 4
	LT_PANEL_V_SCROLL_FIXED = bit 5
	LT_PANEL_H_SCROLL_AUTO = bit 6
	LT_PANEL_V_SCROLL_AUTO = bit 7

	// For LT_PANEL_TABLE and LT_PANEL_STACK.
	LT_PANEL_HORIZONTAL = bit 8
	LT_PANEL_REVERSE = bit 9 // Reverse layout is not supported with LT_PANEL_TABLE yet.

	// For LT_PANEL_SWITCHER.
	LT_PANEL_SWITCHER_MEASURE_LARGEST = bit 15 // Use the largest child to determine size.

	// For LT_PANEL_TABLE.
	LT_PANEL_TABLE_H_JUSTIFY = bit 16
	LT_PANEL_TABLE_V_JUSTIFY = bit 17

	LT_PANEL_RADIO_GROUP = bit 30 // Determines how arrow keys/tabs behave.
};

inttype EsTextboxFlags uint64_t EsElementFlags {
	LT_TEXTBOX_MULTILINE = bit 0
	LT_TEXTBOX_EDIT_BASED = bit 1
	LT_TEXTBOX_MARGIN = bit 2
