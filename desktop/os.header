inttype EsImageDisplayFlags uint64_t EsElementFlags {
	LT_IMAGE_DISPLAY_DECODE_WHEN_NEEDED = bit 0 // The image is only kept in its decoded state when the display is on-screen.
	LT_IMAGE_DISPLAY_MANUAL_SIZE = bit 1 // The display will be manually sized; its size does not depend on the loaded image.
	LT_IMAGE_DISPLAY_FULLY_OPAQUE = bit 2 // The loaded image will always be fully opaque.
};

